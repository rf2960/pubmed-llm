# Copy to a private .env file or configure these in Colab/Hugging Face secrets.
# Do not commit real values.

# SQLite database path. In Colab this usually stays on Drive:
GENE_LAB_DB_PATH=/content/drive/MyDrive/pubmed_llm/gene_function_lab/gene_function_lab.db

# Paper-level cache folder. In Colab this should also stay on Drive:
GDRIVE_CACHE=/content/drive/MyDrive/pubmed_llm/functional_study_cache

# NCBI Entrez email used by Bio.Entrez requests:
ENTREZ_EMAIL=your_email@example.com

# Hugging Face token for model downloads. Prefer Colab Secrets over .env:
HF_TOKEN=<your_hugging_face_token>

# Hugging Face Space / web app secrets:
GOOGLE_SERVICE_ACCOUNT_JSON=<paste_service_account_json_here>
APP_PASSWORD=your_private_password_here
